# Copy to .env for local use. Never commit .env.

# Required policy path for heavy models, OCR models, embedding models, and weights.
LOCAL_MODELS_DIR=./local_models

# Optional runtime locations. Defaults are inside the project and gitignored.
# PKB_DATA_DIR=./data
# PKB_DB_DIR=./db
# PKB_INDEX_DIR=./indexes

# Optional interpreter override for local environments that keep dependencies
# outside the system Python.
# PKB_PYTHON=/absolute/path/to/python3

# Optional OpenAI-compatible API settings.
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# OPENAI_CHAT_MODEL=gpt-4o-mini


# Optional local abstract translation endpoint. Intended for Hy-MT2 or another OpenAI-compatible local translator.
# TRANSLATION_LLM_BASE_URL=http://127.0.0.1:18181/v1
# TRANSLATION_LLM_MODEL=hy-mt2
# HYMT2_OPENAI_BASE_URL=http://127.0.0.1:18181/v1
# HYMT2_MODEL=hy-mt2

# Optional OpenAlex polite-pool settings for literature discovery.
# OPENALEX_MAILTO=you@example.com
# OPENALEX_API_KEY=

# Web server.
HOST=127.0.0.1
PORT=8765
